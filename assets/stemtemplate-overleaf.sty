	\colorlet{themecolour}{DefaultBlue}%
}{%
	\StrLeft{\metaThemeColour}{1}[\@firstchar]%
	\if\@firstchar#%
	\StrGobbleLeft{\metaThemeColour}{1}[\@hexpure]%
	\definecolor{themecolour}{HTML}{\@hexpure}%
	\else
	\colorlet{themecolour}{\metaThemeColour}%
	\fi
}
